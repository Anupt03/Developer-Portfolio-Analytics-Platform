# Server Configuration
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Database
MONGODB_URI=mongodb://localhost:27017/devscope

# Authentication Secrets (Change these in production!)
JWT_SECRET=devscope-jwt-secret-replace-me-123!
JWT_REFRESH_SECRET=devscope-jwt-refresh-secret-replace-me-123!
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# External APIs
# Generate at: https://github.com/settings/tokens (needs 'read:user', 'repo' scopes)
GITHUB_TOKEN=your_github_personal_access_token

# Optional: For AI Career Coach (if empty, uses rule-based heuristic engine)
OPENAI_API_KEY=your_openai_api_key

# Optional: Email Service for Password Reset
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
